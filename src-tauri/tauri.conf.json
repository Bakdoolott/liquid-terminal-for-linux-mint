{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "liquid-terminal",
  "version": "0.1.0",
  "identifier": "com.liquid.terminal",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Liquid Terminal",
        "width": 900,
        "height": 600,
        "resizable": true,
        "transparent": true,
        "backgroundColor": "#00000000",
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
